# Data artifacts (regenerated by `match-charting-project ingest`)
/data/
*.duckdb
*.duckdb.wal
*.parquet

# Generated report data dumps — regenerated by the experiments; keep the .md/figures,
# not the raw CSV slices (large, noisy diffs).
/reports/*.csv

# Generated site data (brackets feed + insights db) — built by CI, served via Pages,
# never committed. Only the docs/ source (html/js/css) is tracked.
/docs/data/

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/

# OS / editors
.DS_Store
.vscode/
.idea/
